# postgres system of record
DATABASE_URL=

# google oauth (separate clients per environment)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# envelope encryption for tokens at rest (base64, 32 bytes) + key rotation version
TOKEN_ENCRYPTION_KEY=
GOOGLE_TOKEN_ENCRYPTION_KEY=
DATA_ENCRYPTION_KEY_VERSION=1
DEVICE_SIGNING_SECRET=

# llm (provider-agnostic; the llm drafts words, never computes availability)
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=

# hosted app + realtime gateway
NEXT_PUBLIC_APP_URL=http://localhost:3000
MAC_WEBSOCKET_URL=ws://localhost:8787
REALTIME_JWT_PRIVATE_KEY=
REALTIME_JWT_PUBLIC_KEY=
INTERNAL_API_TOKEN=
REDIS_URL=

# durable workflows (trigger.dev cloud)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
POSTHOG_KEY=

# mac signing + notarization (release pipeline only)
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=
MACOS_SIGNING_IDENTITY=
